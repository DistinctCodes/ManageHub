PORT=6000
NODE_ENV=development
DATABASE_NAME=your_database_name
DATABASE_PASSWORD=your_database_password
DATABASE_USERNAME=your_database_username
DATABASE_PORT=5432
DATABASE_HOST=your_database_host
JWT_SECRET=your_jwt_secret_here
JWT_ACCESS_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ConvertKit API Configuration
CONVERTKIT_API_KEY=your_convertkit_api_key_here
CONVERTKIT_FORM_ID=your_convertkit_form_id_here

# Cloudinary Configuration (required for profile pictures)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=profile-pictures

# Email Configuration
# Production SMTP Settings (Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Mailtrap (Development/Testing Only)
MAILTRAP_HOST=smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=your_mailtrap_user
MAILTRAP_PASS=your_mailtrap_pass

# Company Information
COMPANY_NAME=ManageHub
SUPPORT_EMAIL=support@yourdomain.com
FRONTEND_URL=http://localhost:3000

# Redis Configuration (for Bull Queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Email Rate Limiting
EMAIL_RATE_LIMIT_PER_HOUR=100

# Email Provider Webhook Secrets (Optional)
SENDGRID_WEBHOOK_SECRET=your_sendgrid_webhook_secret
MAILGUN_WEBHOOK_SECRET=your_mailgun_webhook_secret
SES_SNS_TOPIC_ARN=your_ses_sns_topic_arn

# Soroban / Stellar Escrow Configuration
# On-chain escrow for long-term (MONTHLY/QUARTERLY/YEARLY) bookings.
# Leave SOROBAN_ENABLED=false (or unset) to skip escrow cleanly — no Stellar
# config is required and long-term bookings confirm normally.
# When SOROBAN_ENABLED=true, ALL of the variables below are required or the
# app will refuse to start with an error naming the missing variable(s).
SOROBAN_ENABLED=false
STELLAR_ESCROW_CONTRACT_ID=your_stellar_escrow_contract_id
STELLAR_SECRET_KEY=your_stellar_secret_key
STELLAR_NETWORK=your_stellar_network_passphrase
STELLAR_BENEFICIARY_ADDRESS=your_stellar_beneficiary_address
# Optional — defaults to https://soroban-testnet.stellar.org
STELLAR_HORIZON_URL=https://soroban-testnet.stellar.org
# Scheduled Jobs
# Minutes a PENDING booking may wait for payment before it is auto-cancelled
BOOKING_PAYMENT_TTL_MINUTES=120
