<!DOCTYPE html>
<html>
<head><meta charset="utf-8"><title>Booking Confirmed</title></head>
<body style="font-family:Arial,sans-serif;color:#333;max-width:600px;margin:0 auto;padding:20px">
  <div style="background:#1a1a2e;padding:20px;border-radius:8px 8px 0 0">
    <h1 style="color:#fff;margin:0;font-size:24px">ManageHub</h1>
  </div>
  <div style="background:#f9f9f9;padding:30px;border-radius:0 0 8px 8px;border:1px solid #e0e0e0">
    <h2 style="color:#1a1a2e">Booking Created</h2>
    <p>Hi <strong>{{fullName}}</strong>,</p>
    <p>Your workspace booking has been successfully created. Here are the details:</p>
    <table style="width:100%;border-collapse:collapse;margin:20px 0">
      <tr style="background:#eee">
        <td style="padding:10px;font-weight:bold">Booking ID</td>
        <td style="padding:10px">{{bookingId}}</td>
      </tr>
      <tr>
        <td style="padding:10px;font-weight:bold">Workspace</td>
        <td style="padding:10px">{{workspaceName}}</td>
      </tr>
      <tr style="background:#eee">
        <td style="padding:10px;font-weight:bold">Plan</td>
        <td style="padding:10px">{{planType}}</td>
      </tr>
      <tr>
        <td style="padding:10px;font-weight:bold">Start Date</td>
        <td style="padding:10px">{{startDate}}</td>
      </tr>
      <tr style="background:#eee">
        <td style="padding:10px;font-weight:bold">End Date</td>
        <td style="padding:10px">{{endDate}}</td>
      </tr>
      <tr>
        <td style="padding:10px;font-weight:bold">Seats</td>
        <td style="padding:10px">{{seatCount}}</td>
      </tr>
      <tr style="background:#eee">
        <td style="padding:10px;font-weight:bold">Total Amount</td>
        <td style="padding:10px">₦{{totalAmountNaira}}</td>
      </tr>
    </table>
    <p>Please proceed to complete your payment to confirm the booking.</p>
    <p style="color:#999;font-size:12px">Thank you for choosing ManageHub.</p>
  </div>
</body>
</html>
